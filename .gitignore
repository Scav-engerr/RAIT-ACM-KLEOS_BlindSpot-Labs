# Dependencies (Massive folders that can be re-installed anytime)
node_modules/
jspm_packages/
web_modules/

# Production Builds (The optimized, compressed code for hosting)
dist/
build/
out/

# Environment Secrets (API keys and private passwords)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Logs and Debugging Files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# System Junk Files (Hidden OS files)
.DS_Store
Thumbs.db

# Text Editor / IDE configurations
.vscode/
.idea/
*.suo
*.ntvs*
